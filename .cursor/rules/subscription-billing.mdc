### 2. Usage Analytics for Business Intelligence

```javascript
// backend/src/services/analytics/UsageAnalyticsService.js
export class UsageAnalyticsService {
  constructor(supabase) {
    this.supabase = supabase;
  }

  async getUsageAnalytics(timeframe = '30 days') {
    const startDate = new Date();
    startDate.setDate(startDate.getDate() - parseInt(timeframe));

    const { data: usage } = await this.supabase
      .from('user_usage')
      .select(`
        *,
        user_profiles!inner(subscription_tier, email)
      `)
      .gte('timestamp', startDate.toISOString());

    // Analyze usage patterns
    const analytics = {
      totalQueries: usage.length,
      queriesByType: this.groupBy(usage, 'query_type'),
      revenueByTier: this.calculateRevenue(usage),
      userRetention: await this.calculateRetention(),
      mostPopularFeatures: this.getMostPopularFeatures(usage)
    };

    return analytics;
  }

  groupBy(array, key) {
    return array.reduce((groups, item) => {
      const group = groups[item[key]] || [];
      group.push(item);
      groups[item[key]] = group;
      return groups;
    }, {});
  }

  calculateRevenue(usage) {
    return usage.reduce((revenue, item) => {
      const tier = item.user_profiles.subscription_tier;
      revenue[tier] = (revenue[tier] || 0) + (item.cost || 0);
      return revenue;
    }, {});
  }

  async calculateRetention() {
    // Implementation for calculating user retention metrics
    // This would involve complex SQL queries to determine active users over time
  }

  getMostPopularFeatures(usage) {
    const featureCount = usage.reduce((count, item) => {
      count[item.query_type] = (count[item.query_type] || 0) + 1;
      return count;
    }, {});

    return Object.entries(featureCount)
      .sort(([,a], [,b]) => b - a)
      .slice(0, 10);
  }
}
