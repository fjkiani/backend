# Session State Management and User Behavior Tracking for SaaS

This rule provides guidance for implementing comprehensive session state management, user behavior tracking, and personalized experiences in the SaaS platform.

## Session Management Service

### 1. Core Session Service

```javascript
// backend/src/services/session/SessionService.js
import crypto from 'crypto';
import logger from '../../logger.js';

export class SessionService {
  constructor(supabase) {
    this.supabase = supabase;
  }

  // Start a new user session
  async startSession(userId, sessionData = {}) {
    try {
      const sessionId = crypto.randomUUID();
      const sessionStart = new Date();

      const session = {
        id: sessionId,
        user_id: userId,
        session_start: sessionStart,
        last_activity: sessionStart,
        session_duration: 0,
        user_actions: [],
        current_context: {
          recentQueries: [],
          favoriteSectors: [],
          preferredSources: [],
          searchHistory: [],
          currentWorkflow: null,
          lastViewedFeatures: [],
          ...sessionData
        },
        device_info: {},
        ip_address: null
      };

      const { data, error } = await this.supabase
        .from('user_sessions')
        .insert(session)
        .select()
        .single();

      if (error) throw error;

      logger.info('Session started:', { userId, sessionId });
      return data;
    } catch (error) {
      logger.error('Error starting session:', error);
      throw error;
    }
  }

  // Update session with user activity
  async updateSessionActivity(sessionId, action, actionData = {}) {
    try {
      const now = new Date();

      // Get current session
      const { data: session, error: fetchError } = await this.supabase
        .from('user_sessions')
        .select('*')
        .eq('id', sessionId)
        .single();

      if (fetchError) throw fetchError;

      // Update context based on action
      const updatedContext = this.updateContextFromAction(session.current_context, action, actionData);

      // Add action to history
      const newAction = {
        action,
        timestamp: now,
        data: actionData
      };

      const updatedActions = [...session.user_actions, newAction].slice(-50); // Keep last 50 actions

      // Calculate session duration
      const sessionDuration = Math.floor((now - new Date(session.session_start)) / 1000);

      // Update session
      const { error: updateError } = await this.supabase
        .from('user_sessions')
        .update({
          last_activity: now,
          session_duration: sessionDuration,
          current_context: updatedContext,
          user_actions: updatedActions
        })
        .eq('id', sessionId);

      if (updateError) throw updateError;

      logger.debug('Session updated:', { sessionId, action });
      return updatedContext;
    } catch (error) {
      logger.error('Error updating session:', error);
      throw error;
    }
  }

  // Update context based on user actions
  updateContextFromAction(context, action, actionData) {
    const newContext = { ...context };

    switch (action) {
      case 'query_llm':
        newContext.recentQueries = [actionData.query, ...newContext.recentQueries.slice(0, 9)];
        if (actionData.sector) {
          newContext.favoriteSectors = this.updateFrequencyMap(newContext.favoriteSectors, actionData.sector);
        }
        break;

      case 'view_calendar':
        newContext.lastViewedFeatures = ['calendar', ...newContext.lastViewedFeatures.filter(f => f !== 'calendar')];
        break;

      case 'view_news':
        newContext.lastViewedFeatures = ['news', ...newContext.lastViewedFeatures.filter(f => f !== 'news')];
        if (actionData.source) {
          newContext.preferredSources = this.updateFrequencyMap(newContext.preferredSources, actionData.source);
        }
        break;

      case 'create_dashboard':
        newContext.lastViewedFeatures = ['dashboard', ...newContext.lastViewedFeatures.filter(f => f !== 'dashboard')];
        break;

      case 'start_workflow':
        newContext.currentWorkflow = actionData.workflowId;
        break;

      case 'complete_workflow':
        newContext.currentWorkflow = null;
        break;
    }

    return newContext;
  }

  // Helper to update frequency maps
  updateFrequencyMap(map, key) {
    const newMap = { ...map };
    newMap[key] = (newMap[key] || 0) + 1;
    return newMap;
  }

  // Get session context for personalization
  async getSessionContext(sessionId) {
    try {
      const { data, error } = await this.supabase
        .from('user_sessions')
        .select('current_context, user_actions, last_activity')
        .eq('id', sessionId)
        .single();

      if (error) throw error;
      return data;
    } catch (error) {
      logger.error('Error getting session context:', error);
      return null;
    }
  }

  // End session
  async endSession(sessionId) {
    try {
      const now = new Date();
      const sessionDuration = Math.floor((now - new Date()) / 1000); // Would need session start time

      const { error } = await this.supabase
        .from('user_sessions')
        .update({
          session_duration: sessionDuration,
          last_activity: now
        })
        .eq('id', sessionId);

      if (error) throw error;

      logger.info('Session ended:', { sessionId });
    } catch (error) {
      logger.error('Error ending session:', error);
    }
  }

  // Get user behavior analytics
  async getUserBehaviorAnalytics(userId, timeframe = '30 days') {
    try {
      const startDate = new Date();
      startDate.setDate(startDate.getDate() - parseInt(timeframe.split(' ')[0]));

      const { data: sessions, error } = await this.supabase
        .from('user_sessions')
        .select('*')
        .eq('user_id', userId)
        .gte('session_start', startDate.toISOString())
        .order('session_start', { ascending: false });

      if (error) throw error;

      const analytics = {
        totalSessions: sessions.length,
        averageSessionDuration: this.calculateAverageDuration(sessions),
        mostUsedFeatures: this.analyzeFeatureUsage(sessions),
        preferredSources: this.analyzeSourcePreferences(sessions),
        favoriteSectors: this.analyzeSectorPreferences(sessions),
        sessionPatterns: this.analyzeSessionPatterns(sessions),
        recentActivity: sessions.slice(0, 5)
      };

      return analytics;
    } catch (error) {
      logger.error('Error getting user behavior analytics:', error);
      throw error;
    }
  }

  calculateAverageDuration(sessions) {
    if (sessions.length === 0) return 0;
    const totalDuration = sessions.reduce((sum, session) => sum + (session.session_duration || 0), 0);
    return Math.round(totalDuration / sessions.length);
  }

  analyzeFeatureUsage(sessions) {
    const featureCount = {};

    sessions.forEach(session => {
      session.user_actions.forEach(action => {
        const feature = this.actionToFeature(action.action);
        if (feature) {
          featureCount[feature] = (featureCount[feature] || 0) + 1;
        }
      });
    });

    return Object.entries(featureCount)
      .sort(([,a], [,b]) => b - a)
      .slice(0, 5);
  }

  actionToFeature(action) {
    const mapping = {
      'query_llm': 'llm_analysis',
      'view_calendar': 'calendar',
      'view_news': 'news',
      'create_dashboard': 'dashboard',
      'start_workflow': 'workflows'
    };
    return mapping[action] || action;
  }

  analyzeSourcePreferences(sessions) {
    const sourceCount = {};

    sessions.forEach(session => {
      Object.entries(session.current_context.preferredSources || {}).forEach(([source, count]) => {
        sourceCount[source] = (sourceCount[source] || 0) + count;
      });
    });

    return Object.entries(sourceCount)
      .sort(([,a], [,b]) => b - a);
  }

  analyzeSectorPreferences(sessions) {
    const sectorCount = {};

    sessions.forEach(session => {
      Object.entries(session.current_context.favoriteSectors || {}).forEach(([sector, count]) => {
        sectorCount[sector] = (sectorCount[sector] || 0) + count;
      });
    });

    return Object.entries(sectorCount)
      .sort(([,a], [,b]) => b - a);
  }

  analyzeSessionPatterns(sessions) {
    const patterns = {
      peakHours: this.getPeakHours(sessions),
      averageActionsPerSession: this.getAverageActionsPerSession(sessions),
      commonWorkflows: this.getCommonWorkflows(sessions)
    };

    return patterns;
  }

  getPeakHours(sessions) {
    const hourCount = {};

    sessions.forEach(session => {
      const hour = new Date(session.session_start).getHours();
      hourCount[hour] = (hourCount[hour] || 0) + 1;
    });

    return Object.entries(hourCount)
      .sort(([,a], [,b]) => b - a)
      .slice(0, 3);
  }

  getAverageActionsPerSession(sessions) {
    if (sessions.length === 0) return 0;
    const totalActions = sessions.reduce((sum, session) => sum + session.user_actions.length, 0);
    return Math.round(totalActions / sessions.length);
  }

  getCommonWorkflows(sessions) {
    const workflowCount = {};

    sessions.forEach(session => {
      session.user_actions.forEach(action => {
        if (action.action === 'start_workflow' && action.data.workflowId) {
          workflowCount[action.data.workflowId] = (workflowCount[action.data.workflowId] || 0) + 1;
        }
      });
    });

    return Object.entries(workflowCount)
      .sort(([,a], [,b]) => b - a)
      .slice(0, 5);
  }
}
```

## Frontend Session Management

### 1. Session Context Hook

```typescript
// src/hooks/useSession.ts
import { useState, useEffect, useCallback, createContext, useContext } from 'react';
import { useAuth } from './useAuth';
import { supabase } from '../services/supabase';

interface SessionContextType {
  sessionId: string | null;
  context: any;
  updateContext: (action: string, data?: any) => Promise<void>;
  sessionAnalytics: any;
  loading: boolean;
}

const SessionContext = createContext<SessionContextType | undefined>(undefined);

export const SessionProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {
  const { user } = useAuth();
  const [sessionId, setSessionId] = useState<string | null>(null);
  const [context, setContext] = useState<any>({});
  const [sessionAnalytics, setSessionAnalytics] = useState<any>(null);
  const [loading, setLoading] = useState(false);

  const startSession = useCallback(async () => {
    if (!user) return;

    try {
      setLoading(true);
      const response = await fetch('/api/session/start', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${(await supabase.auth.getSession()).data.session?.access_token}`,
        },
        body: JSON.stringify({
          userAgent: navigator.userAgent,
          timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
          screenSize: `${window.screen.width}x${window.screen.height}`
        }),
      });

      if (!response.ok) throw new Error('Failed to start session');

      const sessionData = await response.json();
      setSessionId(sessionData.id);
      setContext(sessionData.current_context);
    } catch (error) {
      console.error('Error starting session:', error);
    } finally {
      setLoading(false);
    }
  }, [user]);

  const updateContext = useCallback(async (action: string, data: any = {}) => {
    if (!sessionId) return;

    try {
      const response = await fetch('/api/session/update', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${(await supabase.auth.getSession()).data.session?.access_token}`,
        },
        body: JSON.stringify({
          sessionId,
          action,
          data
        }),
      });

      if (!response.ok) throw new Error('Failed to update session');

      const updatedContext = await response.json();
      setContext(updatedContext);
    } catch (error) {
      console.error('Error updating session context:', error);
    }
  }, [sessionId]);

  const fetchSessionAnalytics = useCallback(async () => {
    if (!user) return;

    try {
      const response = await fetch('/api/session/analytics', {
        headers: {
          'Authorization': `Bearer ${(await supabase.auth.getSession()).data.session?.access_token}`,
        },
      });

      if (!response.ok) throw new Error('Failed to fetch analytics');

      const analytics = await response.json();
      setSessionAnalytics(analytics);
    } catch (error) {
      console.error('Error fetching session analytics:', error);
    }
  }, [user]);

  useEffect(() => {
    if (user) {
      startSession();
      fetchSessionAnalytics();
    }
  }, [user, startSession, fetchSessionAnalytics]);

  const value = {
    sessionId,
    context,
    updateContext,
    sessionAnalytics,
    loading,
  };

  return (
    <SessionContext.Provider value={value}>
      {children}
    </SessionContext.Provider>
  );
};

export const useSession = () => {
  const context = useContext(SessionContext);
  if (context === undefined) {
    throw new Error('useSession must be used within a SessionProvider');
  }
  return context;
};
```

