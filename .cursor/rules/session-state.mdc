```typescript
// src/components/Session/PersonalizedSuggestions.tsx
import React from 'react';
import { useSession } from '../../hooks/useSession';
import { useAuth } from '../../hooks/useAuth';

export const PersonalizedSuggestions: React.FC = () => {
  const { context } = useSession();
  const { user } = useAuth();

  const getSuggestions = () => {
    if (!context) return [];

    const suggestions = [];

    // Suggest based on favorite sectors
    const topSectors = Object.entries(context.favoriteSectors || {})
      .sort(([,a], [,b]) => b - a)
      .slice(0, 3);

    if (topSectors.length > 0) {
      suggestions.push({
        type: 'sector',
        title: 'Continue exploring your favorite sectors',
        description: `Based on your activity, you're interested in: ${topSectors.map(([sector]) => sector).join(', ')}`,
        action: () => {/* Navigate to sector analysis */}
      });
    }

    // Suggest based on recent queries
    if (context.recentQueries?.length > 0) {
      suggestions.push({
        type: 'query',
        title: 'Recent analysis patterns',
        description: 'Continue with similar market analyses you\'ve been running',
        action: () => {/* Show recent queries */}
      });
    }

    // Suggest based on preferred sources
    const topSources = Object.entries(context.preferredSources || {})
      .sort(([,a], [,b]) => b - a)
      .slice(0, 2);

    if (topSources.length > 0) {
      suggestions.push({
        type: 'source',
        title: 'Your preferred news sources',
        description: `Quick access to ${topSources.map(([source]) => source).join(' and ')}`,
        action: () => {/* Navigate to preferred sources */}
      });
    }

    // Suggest based on last viewed features
    if (context.lastViewedFeatures?.length > 0) {
      const lastFeature = context.lastViewedFeatures[0];
      suggestions.push({
        type: 'feature',
        title: 'Continue where you left off',
        description: `Pick up from your last ${lastFeature} session`,
        action: () => {/* Navigate to last feature */}
      });
    }

    return suggestions;
  };

  const suggestions = getSuggestions();

  if (suggestions.length === 0) return null;

  return (
    <div className="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
      <h3 className="text-lg font-semibold text-blue-900 mb-3">
        🎯 Personalized Suggestions
      </h3>

      <div className="space-y-3">
        {suggestions.map((suggestion, index) => (
          <div key={index} className="flex items-start space-x-3">
            <div className="flex-shrink-0">
              <div className="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                {suggestion.type === 'sector' && '📈'}
                {suggestion.type === 'query' && '🔍'}
                {suggestion.type === 'source' && '📰'}
                {suggestion.type === 'feature' && '⚡'}
              </div>
            </div>
            <div className="flex-1">
              <h4 className="text-sm font-medium text-blue-900">
                {suggestion.title}
              </h4>
              <p className="text-sm text-blue-700 mb-2">
                {suggestion.description}
              </p>
              <button
                onClick={suggestion.action}
                className="text-xs bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700"
              >
                Explore
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
};
