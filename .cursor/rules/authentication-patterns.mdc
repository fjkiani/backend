# Authentication and Authorization Patterns for SaaS

This rule provides guidance for implementing secure user authentication and authorization in the SaaS platform.

## Authentication Flow

### 1. Frontend Authentication

```typescript
// src/hooks/useAuth.ts
import { createContext, useContext, useEffect, useState } from 'react';
import { User, Session, AuthChangeEvent } from '@supabase/supabase-js';
import { supabase } from '../services/supabase';

interface AuthContextType {
  user: User | null;
  session: Session | null;
  profile: UserProfile | null;
  loading: boolean;
  signUp: (email: string, password: string) => Promise<void>;
  signIn: (email: string, password: string) => Promise<void>;
  signOut: () => Promise<void>;
  updateProfile: (updates: Partial<UserProfile>) => Promise<void>;
}

const AuthContext = createContext<AuthContextType | undefined>(undefined);

export const AuthProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {
  const [user, setUser] = useState<User | null>(null);
  const [session, setSession] = useState<Session | null>(null);
  const [profile, setProfile] = useState<UserProfile | null>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    // Get initial session
    supabase.auth.getSession().then(({ data: { session } }) => {
      setSession(session);
      setUser(session?.user ?? null);
      if (session?.user) {
        fetchUserProfile(session.user.id);
      }
    });

    // Listen for auth changes
    const {
      data: { subscription },
    } = supabase.auth.onAuthStateChange(async (event: AuthChangeEvent, session: Session | null) => {
      setSession(session);
      setUser(session?.user ?? null);
      
      if (session?.user) {
        await fetchUserProfile(session.user.id);
      } else {
        setProfile(null);
      }
      
      setLoading(false);
    });

    return () => subscription.unsubscribe();
  }, []);

  const fetchUserProfile = async (userId: string) => {
    try {
      const { data, error } = await supabase
        .from('user_profiles')
        .select('*')
        .eq('id', userId)
        .single();

      if (error) throw error;
      setProfile(data);
    } catch (error) {
      console.error('Error fetching user profile:', error);
    }
  };

  const signUp = async (email: string, password: string) => {
    const { data, error } = await supabase.auth.signUp({
      email,
      password,
    });
    
    if (error) throw error;
    
    // Create user profile
    if (data.user) {
      await supabase
        .from('user_profiles')
        .insert({
          id: data.user.id,
          email: data.user.email,
        });
    }
  };

  const signIn = async (email: string, password: string) => {
    const { data, error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });
    
    if (error) throw error;
  };

  const signOut = async () => {
    const { error } = await supabase.auth.signOut();
    if (error) throw error;
  };

  const updateProfile = async (updates: Partial<UserProfile>) => {
    if (!user) throw new Error('No user logged in');
    
    const { data, error } = await supabase
      .from('user_profiles')
      .update(updates)
      .eq('id', user.id)
      .select()
      .single();
    
    if (error) throw error;
    setProfile(data);
  };

  const value = {
    user,
    session,
    profile,
    loading,
    signUp,
    signIn,
    signOut,
    updateProfile,
  };

  return (
    <AuthContext.Provider value={value}>
      {children}
    </AuthContext.Provider>
  );
};

export const useAuth = () => {
  const context = useContext(AuthContext);
  if (context === undefined) {
    throw new Error('useAuth must be used within an AuthProvider');
  }
  return context;
};
```

### 2. Backend Authentication Middleware

```javascript
// backend/src/middleware/auth.js
import jwt from 'jsonwebtoken';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(process.env.VITE_SUPABASE_URL, process.env.VITE_SUPABASE_KEY);

export const authenticateUser = async (req, res, next) => {
  try {
    const authHeader = req.headers.authorization;
    
    if (!authHeader || !authHeader.startsWith('Bearer ')) {
      return res.status(401).json({ error: 'Missing or invalid authorization header' });
    }

    const token = authHeader.substring(7);
    
    // Verify token with Supabase
    const { data: { user }, error } = await supabase.auth.getUser(token);
    
    if (error || !user) {
      return res.status(401).json({ error: 'Invalid or expired token' });
    }

    // Get user profile
    const { data: profile, error: profileError } = await supabase
      .from('user_profiles')
      .select('*')
      .eq('id', user.id)
      .single();

    if (profileError) {
      console.error('Error fetching user profile:', profileError);
      return res.status(500).json({ error: 'Error fetching user profile' });
    }

    // Attach user info to request
    req.user = {
      id: user.id,
      email: user.email,
      profile: profile
    };
    
    req.supabase = supabase;
    
    next();
  } catch (error) {
    console.error('Authentication error:', error);
    res.status(500).json({ error: 'Internal server error' });
  }
};

// Optional middleware for public routes that may have user context
export const optionalAuth = async (req, res, next) => {
  try {
    const authHeader = req.headers.authorization;
    
    if (authHeader && authHeader.startsWith('Bearer ')) {
      const token = authHeader.substring(7);
      
      const { data: { user }, error } = await supabase.auth.getUser(token);
      
      if (!error && user) {
        const { data: profile } = await supabase
          .from('user_profiles')
          .select('*')
          .eq('id', user.id)
          .single();
        
        req.user = {
          id: user.id,
          email: user.email,
          profile: profile || null
        };
      }
    }
    
    req.supabase = supabase;
    next();
  } catch (error) {
    console.error('Optional auth error:', error);
    req.supabase = supabase;
    next();
  }
};
```

## Authorization Patterns

### 1. Role-Based Access Control

```javascript
// backend/src/middleware/authorization.js
export const requireSubscription = (requiredTiers = ['pro', 'enterprise']) => {
  return (req, res, next) => {
    if (!req.user) {
      return res.status(401).json({ error: 'Authentication required' });
    }

    const userTier = req.user.profile?.subscription_tier || 'free';
    
    if (!requiredTiers.includes(userTier)) {
      return res.status(403).json({ 
        error: 'Insufficient subscription tier',
        required: requiredTiers,
        current: userTier,
        message: `This feature requires ${requiredTiers.join(' or ')} subscription`
      });
    }

    next();
  };
};

export const requireOwnership = (resourceUserIdField = 'user_id') => {
  return (req, res, next) => {
    if (!req.user) {
      return res.status(401).json({ error: 'Authentication required' });
    }

    const resourceUserId = req.body[resourceUserIdField] || req.params[resourceUserIdField];
    
    if (resourceUserId && resourceUserId !== req.user.id) {
      return res.status(403).json({ error: 'Access denied: Resource does not belong to user' });
    }

    next();
  };
};
```

### 2. Usage-Based Authorization

```javascript
// backend/src/middleware/rateLimiter.js
export const checkUsageLimit = (queryType = 'llm', credits = 1) => {
  return async (req, res, next) => {
    if (!req.user) {
      return next(); // Let auth middleware handle this
    }

    try {
      // Check current usage against limits
      const { data: profile, error } = await req.supabase
        .from('user_profiles')
        .select('query_count, query_limit, subscription_tier')
        .eq('id', req.user.id)
        .single();

      if (error) {
        console.error('Error checking usage limit:', error);
        return res.status(500).json({ error: 'Error checking usage limit' });
      }

      const canProceed = profile.query_count + credits <= profile.query_limit;
      
      if (!canProceed) {
        return res.status(429).json({
          error: 'Usage limit exceeded',
          message: `You have used ${profile.query_count} of ${profile.query_limit} queries`,
          remaining: 0,
          resetDate: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000), // 30 days
          upgradeUrl: '/subscription/upgrade'
        });
      }

      // Attach usage info to request
      req.usageInfo = {
        currentUsage: profile.query_count,
        limit: profile.query_limit,
        remaining: profile.query_limit - profile.query_count - credits,
        tier: profile.subscription_tier
      };

      next();
    } catch (error) {
      console.error('Rate limiter error:', error);
      res.status(500).json({ error: 'Internal server error' });
    }
  };
};
```

## API Route Patterns

### 1. Protected Route Pattern

```javascript
// backend/src/routes/protectedRoute.js
import express from 'express';
import { authenticateUser, checkUsageLimit, requireSubscription } from '../middleware/auth.js';

const router = express.Router();

// Apply authentication to all routes
router.use(authenticateUser);

// Example protected endpoint
router.post('/analyze-market', checkUsageLimit('llm', 1), async (req, res) => {
  try {
    const { query } = req.body;
    const userId = req.user.id;
    
    // Process the query
    const result = await processMarketAnalysis(query, userId);
    
    // Track usage
    await req.supabase
      .from('user_usage')
      .insert({
        user_id: userId,
        query_type: 'llm',
        query_subtype: 'market-analysis',
        credits_used: 1,
        metadata: { query_length: query.length }
      });
    
    // Update usage count
    await req.supabase.rpc('increment_user_query_count', { user_id: userId });
    
    res.json({ result, usage: req.usageInfo });
  } catch (error) {
    console.error('Market analysis error:', error);
    res.status(500).json({ error: 'Analysis failed' });
  }
});

// Premium feature endpoint
router.post('/advanced-analysis', 
  requireSubscription(['pro', 'enterprise']), 
  checkUsageLimit('llm', 2), 
  async (req, res) => {
    // Implementation for premium analysis
  }
);

export default router;
```

### 2. Public Route with Optional Auth

```javascript
// backend/src/routes/publicRoute.js
import express from 'express';
import { optionalAuth } from '../middleware/auth.js';

const router = express.Router();

router.use(optionalAuth);

router.get('/market-overview', async (req, res) => {
  try {
    const isAuthenticated = !!req.user;
    let result;
    
    if (isAuthenticated) {
      // Personalized results for authenticated users
      result = await getPersonalizedMarketOverview(req.user.id);
    } else {
      // Basic results for anonymous users
      result = await getBasicMarketOverview();
    }
    
    res.json({ 
      result, 
      isAuthenticated,
      userInfo: isAuthenticated ? {
        tier: req.user.profile.subscription_tier,
        usage: req.user.profile.query_count
      } : null
    });
  } catch (error) {
    console.error('Market overview error:', error);
    res.status(500).json({ error: 'Failed to fetch market overview' });
  }
});

export default router;
```

## Frontend Component Patterns

### 1. Protected Component Pattern

```typescript
// src/components/ProtectedComponent.tsx
import React from 'react';
import { useAuth } from '../hooks/useAuth';
import { LoginPrompt } from './Auth/LoginPrompt';
import { SubscriptionRequired } from './Subscription/SubscriptionRequired';
import { UsageLimitWarning } from './Subscription/UsageLimitWarning';

interface ProtectedComponentProps {
  children: React.ReactNode;
  requiredTiers?: string[];
  showUsageWarning?: boolean;
}

export const ProtectedComponent: React.FC<ProtectedComponentProps> = ({
  children,
  requiredTiers = [],
  showUsageWarning = true
}) => {
  const { user, profile, loading } = useAuth();

  if (loading) {
    return <div className="flex justify-center p-8"><div className="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div></div>;
  }

  if (!user) {
    return <LoginPrompt />;
  }

  if (requiredTiers.length > 0 && !requiredTiers.includes(profile?.subscription_tier || 'free')) {
    return <SubscriptionRequired requiredTiers={requiredTiers} />;
  }

  return (
    <div className="relative">
      {showUsageWarning && profile && (
        <UsageLimitWarning 
          currentUsage={profile.query_count} 
          limit={profile.query_limit} 
        />
      )}
      {children}
    </div>
  );
};
```

### 2. Usage Tracking Hook

```typescript
// src/hooks/useUsage.ts
import { useState, useEffect } from 'react';
import { useAuth } from './useAuth';
import { supabase } from '../services/supabase';

interface UsageData {
  currentUsage: number;
  limit: number;
  remaining: number;
  tier: string;
  usagePercentage: number;
}

export const useUsage = () => {
  const { user } = useAuth();
  const [usage, setUsage] = useState<UsageData | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    if (!user) {
      setLoading(false);
      return;
    }

    fetchUsage();
  }, [user]);

  const fetchUsage = async () => {
    try {
      setLoading(true);
      const { data, error } = await supabase
        .from('user_profiles')
        .select('query_count, query_limit, subscription_tier')
        .eq('id', user!.id)
        .single();

      if (error) throw error;

      const usageData: UsageData = {
        currentUsage: data.query_count,
        limit: data.query_limit,
        remaining: data.query_limit - data.query_count,
        tier: data.subscription_tier,
        usagePercentage: (data.query_count / data.query_limit) * 100
      };

      setUsage(usageData);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to fetch usage');
    } finally {
      setLoading(false);
    }
  };

  const refreshUsage = () => {
    fetchUsage();
  };

  return { usage, loading, error, refreshUsage };
};
```

## Security Best Practices

1. **Token Management**: Use short-lived access tokens with refresh tokens
2. **Password Policies**: Enforce strong passwords with Supabase Auth settings
3. **Rate Limiting**: Implement both user-level and IP-level rate limiting
4. **Audit Logging**: Log all authentication and authorization events
5. **Session Management**: Implement proper session timeouts and invalidation
6. **Data Validation**: Validate all user inputs on both frontend and backend
7. **Error Handling**: Don't expose sensitive information in error messages
8. **CORS Configuration**: Properly configure CORS for security

Always validate user permissions before processing any request and implement proper error handling for authentication failures.
