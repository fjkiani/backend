  const { usage } = useUsage();
  const { user } = useAuth();

  if (!usage || !user) return null;

  const showWarning = usage.usagePercentage > 80;
  const showCritical = usage.usagePercentage >= 95;

  if (showCritical) {
    return (
      <div className="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
