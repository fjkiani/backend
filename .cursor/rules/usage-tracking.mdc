# Usage Tracking and Rate Limiting Patterns for SaaS

This rule provides guidance for implementing comprehensive usage tracking, rate limiting, and quota management in the SaaS platform.

## Usage Tracking Service

### 1. Core Usage Tracking Service

```javascript
// backend/src/services/usage/UsageTrackingService.js
import logger from '../../logger.js';

export class UsageTrackingService {
  constructor(supabase) {
    this.supabase = supabase;
  }

  // Check user quota before processing request
  async checkUserQuota(userId, queryType = 'llm') {
    try {
      const { data: profile, error } = await this.supabase
        .from('user_profiles')
        .select('query_count, query_limit, subscription_tier')
        .eq('id', userId)
        .single();

      if (error) {
        logger.error('Error checking user quota:', error);
        throw error;
      }

      const canProceed = profile.query_count < profile.query_limit;
      const remaining = Math.max(0, profile.query_limit - profile.query_count);

      return {
        canProceed,
        remaining,
        currentUsage: profile.query_count,
        limit: profile.query_limit,
        tier: profile.subscription_tier,
        usagePercentage: (profile.query_count / profile.query_limit) * 100
      };
    } catch (error) {
      logger.error('Error in checkUserQuota:', error);
      throw error;
    }
  }

  // Track usage after successful operation
  async trackUsage(userId, usageData) {
    try {
      const {
        queryType = 'llm',
        querySubtype = null,
        tokensUsed = 0,
        creditsUsed = 1,
        cost = 0,
        metadata = {}
      } = usageData;

      // Insert usage record
      const { data: usageRecord, error: usageError } = await this.supabase
        .from('user_usage')
        .insert({
          user_id: userId,
          query_type: queryType,
          query_subtype: querySubtype,
          tokens_used: tokensUsed,
          credits_used: creditsUsed,
          cost: cost,
          metadata: metadata
        })
        .select()
        .single();

      if (usageError) {
        logger.error('Error inserting usage record:', usageError);
        throw usageError;
      }

      // Update user profile usage count
      const { error: updateError } = await this.supabase.rpc('increment_user_query_count', {
        user_id: userId
      });

      if (updateError) {
        logger.error('Error updating user query count:', updateError);
        throw updateError;
      }

      // Update usage summary for quick checks
      await this.updateUsageSummary(userId, queryType, creditsUsed);

      logger.info('Usage tracked successfully:', {
        userId,
        queryType,
        creditsUsed,
        usageRecordId: usageRecord.id
      });

      return usageRecord;
    } catch (error) {
      logger.error('Error in trackUsage:', error);
      throw error;
    }
  }

  // Update usage summary table
  async updateUsageSummary(userId, queryType, creditsUsed) {
    try {
      const today = new Date().toISOString().split('T')[0];

      // Get or create usage summary for today
      const { data: existing } = await this.supabase
        .from('user_usage_summary')
        .select('*')
        .eq('user_id', userId)
        .eq('period_start', today)
        .single();

      if (existing) {
        // Update existing record
        const updates = {
          total_queries: existing.total_queries + creditsUsed
        };

        if (queryType === 'llm') {
          updates.llm_queries = existing.llm_queries + creditsUsed;
        }

        await this.supabase
          .from('user_usage_summary')
          .update(updates)
          .eq('user_id', userId)
          .eq('period_start', today);
      } else {
        // Create new record
        await this.supabase
          .from('user_usage_summary')
          .insert({
            user_id: userId,
            total_queries: creditsUsed,
            llm_queries: queryType === 'llm' ? creditsUsed : 0,
            period_start: today
          });
      }
    } catch (error) {
      logger.error('Error updating usage summary:', error);
      // Don't throw - this is not critical
    }
  }

  // Get usage history for user
  async getUsageHistory(userId, timeframe = '30 days') {
    try {
      const startDate = new Date();
      startDate.setDate(startDate.getDate() - parseInt(timeframe.split(' ')[0]));

      const { data, error } = await this.supabase
        .from('user_usage')
        .select('*')
        .eq('user_id', userId)
        .gte('timestamp', startDate.toISOString())
        .order('timestamp', { ascending: false });

      if (error) {
        logger.error('Error fetching usage history:', error);
        throw error;
      }

      return data;
    } catch (error) {
      logger.error('Error in getUsageHistory:', error);
      throw error;
    }
  }

  // Get usage statistics
  async getUsageStats(userId) {
    try {
      const { data: profile } = await this.supabase
        .from('user_profiles')
        .select('query_count, query_limit, subscription_tier')
        .eq('id', userId)
        .single();

      const { data: todayUsage } = await this.supabase
        .from('user_usage_summary')
        .select('*')
        .eq('user_id', userId)
        .eq('period_start', new Date().toISOString().split('T')[0])
        .single();

      return {
        currentUsage: profile.query_count,
        limit: profile.query_limit,
        remaining: profile.query_limit - profile.query_count,
        tier: profile.subscription_tier,
        usagePercentage: (profile.query_count / profile.query_limit) * 100,
        todayQueries: todayUsage?.total_queries || 0,
        todayLLMQueries: todayUsage?.llm_queries || 0
      };
    } catch (error) {
      logger.error('Error in getUsageStats:', error);
      throw error;
    }
  }

  // Reset usage (for monthly resets or admin actions)
  async resetUsage(userId, resetType = 'monthly') {
    try {
      const { error } = await this.supabase
        .from('user_profiles')
        .update({
          query_count: 0,
          updated_at: new Date().toISOString()
        })
        .eq('id', userId);

      if (error) {
        logger.error('Error resetting usage:', error);
        throw error;
      }

      // Log the reset
      await this.supabase
        .from('user_usage')
        .insert({
          user_id: userId,
          query_type: 'system',
          metadata: { action: 'usage_reset', resetType }
        });

      logger.info('Usage reset successfully:', { userId, resetType });
    } catch (error) {
      logger.error('Error in resetUsage:', error);
      throw error;
    }
  }
}
```

### 2. Rate Limiting Middleware

```javascript
// backend/src/middleware/rateLimiter.js
import { UsageTrackingService } from '../services/usage/UsageTrackingService.js';
import logger from '../logger.js';

export const checkUsageLimit = (queryType = 'llm', credits = 1) => {
  return async (req, res, next) => {
    if (!req.user) {
      return next(); // Let auth middleware handle this
    }

    try {
      const usageService = new UsageTrackingService(req.supabase);
      const quota = await usageService.checkUserQuota(req.user.id, queryType);

      if (!quota.canProceed) {
        logger.warn('Usage limit exceeded:', {
          userId: req.user.id,
          queryType,
          currentUsage: quota.currentUsage,
          limit: quota.limit
        });

        return res.status(429).json({
          error: 'Usage limit exceeded',
          message: `You have used ${quota.currentUsage} of ${quota.limit} queries`,
          remaining: 0,
          resetDate: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000), // 30 days
          upgradeUrl: '/subscription/upgrade',
          tier: quota.tier,
          usagePercentage: quota.usagePercentage
        });
      }

      // Attach usage info to request for later use
      req.usageInfo = {
        currentUsage: quota.currentUsage,
        limit: quota.limit,
        remaining: quota.remaining,
        tier: quota.tier,
        usagePercentage: quota.usagePercentage,
        willExceed: (quota.currentUsage + credits) > quota.limit
      };

      // Add usage tracking helper to request
      req.trackUsage = async (usageData) => {
        return await usageService.trackUsage(req.user.id, {
          queryType,
          creditsUsed: credits,
          ...usageData
        });
      };

      next();
    } catch (error) {
      logger.error('Rate limiter error:', error);
      res.status(500).json({ error: 'Internal server error' });
    }
  };
};

// Specialized middleware for different endpoints
export const llmRateLimit = checkUsageLimit('llm', 1);
export const analysisRateLimit = checkUsageLimit('analysis', 1);
export const calendarRateLimit = checkUsageLimit('calendar', 1);
export const newsRateLimit = checkUsageLimit('news', 1);

// Middleware for premium features
export const premiumFeatureLimit = (requiredTiers = ['pro', 'enterprise']) => {
  return (req, res, next) => {
    if (!req.user) {
      return res.status(401).json({ error: 'Authentication required' });
    }

    const userTier = req.user.profile?.subscription_tier || 'free';

    if (!requiredTiers.includes(userTier)) {
      return res.status(403).json({
        error: 'Premium feature',
        message: `This feature requires ${requiredTiers.join(' or ')} subscription`,
        currentTier: userTier,
        requiredTiers: requiredTiers,
        upgradeUrl: '/subscription/upgrade'
      });
    }

    next();
  };
};
```

## Frontend Usage Management

### 1. Usage Tracking Hook

```typescript
// src/hooks/useUsage.ts
import { useState, useEffect, useCallback } from 'react';
import { useAuth } from './useAuth';
import { supabase } from '../services/supabase';

interface UsageStats {
  currentUsage: number;
  limit: number;
  remaining: number;
  tier: string;
  usagePercentage: number;
  todayQueries: number;
  todayLLMQueries: number;
}

interface UsageHistory {
  id: string;
  query_type: string;
  query_subtype: string | null;
  timestamp: string;
  credits_used: number;
  cost: number;
  metadata: any;
}

export const useUsage = () => {
  const { user } = useAuth();
  const [usage, setUsage] = useState<UsageStats | null>(null);
  const [history, setHistory] = useState<UsageHistory[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  const fetchUsage = useCallback(async () => {
    if (!user) return;

    try {
      setLoading(true);
      setError(null);

      const response = await fetch('/api/user/usage', {
        headers: {
          'Authorization': `Bearer ${(await supabase.auth.getSession()).data.session?.access_token}`,
        },
      });

      if (!response.ok) throw new Error('Failed to fetch usage');

      const data = await response.json();
      setUsage(data.stats);
      setHistory(data.history);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to fetch usage');
    } finally {
      setLoading(false);
    }
  }, [user]);

  useEffect(() => {
    fetchUsage();
  }, [fetchUsage]);

  const refreshUsage = useCallback(() => {
    fetchUsage();
  }, [fetchUsage]);

  return { usage, history, loading, error, refreshUsage };
};
```

### 2. Usage Dashboard Components

```typescript
// src/components/Usage/UsageGauge.tsx
import React from 'react';
import { useUsage } from '../../hooks/useUsage';

export const UsageGauge: React.FC = () => {
  const { usage, loading } = useUsage();

  if (loading || !usage) {
    return <div className="animate-pulse bg-gray-200 h-4 rounded"></div>;
  }

  const isNearLimit = usage.usagePercentage > 80;
  const isAtLimit = usage.usagePercentage >= 100;

  return (
    <div className="bg-white rounded-lg shadow p-4">
      <div className="flex justify-between items-center mb-2">
        <h3 className="text-sm font-medium text-gray-700">Usage</h3>
        <span className="text-sm text-gray-500">
          {usage.currentUsage} / {usage.limit}
        </span>
      </div>

      <div className="w-full bg-gray-200 rounded-full h-2 mb-2">
        <div
          className={`h-2 rounded-full transition-all duration-300 ${
            isAtLimit ? 'bg-red-500' :
            isNearLimit ? 'bg-yellow-500' : 'bg-blue-500'
          }`}
          style={{ width: `${Math.min(usage.usagePercentage, 100)}%` }}
        ></div>
      </div>

      {isNearLimit && (
        <div className="text-xs text-yellow-600">
          ⚠️ Approaching usage limit. {usage.remaining} queries remaining.
        </div>
      )}

      {isAtLimit && (
        <div className="text-xs text-red-600">
          🚫 Usage limit reached. Upgrade to continue.
        </div>
      )}
    </div>
  );
};
