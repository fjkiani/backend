## Usage Analytics and Insights

### 1. Usage Analytics Service

```javascript
// backend/src/services/analytics/UsageAnalyticsService.js
export class UsageAnalyticsService {
  constructor(supabase) {
    this.supabase = supabase;
  }

  // Get user usage patterns
  async getUserUsagePatterns(userId, timeframe = '30 days') {
    try {
      const startDate = new Date();
      startDate.setDate(startDate.getDate() - parseInt(timeframe.split(' ')[0]));

      const { data } = await this.supabase
        .from('user_usage')
        .select('*')
        .eq('user_id', userId)
        .gte('timestamp', startDate.toISOString());

      // Analyze patterns
      const patterns = {
        mostUsedFeatures: this.getMostUsedFeatures(data),
        peakUsageHours: this.getPeakUsageHours(data),
        queryTypeDistribution: this.getQueryTypeDistribution(data),
        averageDailyUsage: this.getAverageDailyUsage(data),
        usageTrend: this.getUsageTrend(data)
      };

      return patterns;
    } catch (error) {
      logger.error('Error getting usage patterns:', error);
      throw error;
    }
  }

  getMostUsedFeatures(usage) {
    const featureCount = usage.reduce((count, item) => {
      const key = item.query_subtype || item.query_type;
      count[key] = (count[key] || 0) + 1;
      return count;
    }, {});

    return Object.entries(featureCount)
      .sort(([,a], [,b]) => b - a)
      .slice(0, 5);
  }

  getPeakUsageHours(usage) {
    const hourCount = usage.reduce((count, item) => {
      const hour = new Date(item.timestamp).getHours();
      count[hour] = (count[hour] || 0) + 1;
      return count;
    }, {});

    return Object.entries(hourCount)
      .sort(([,a], [,b]) => b - a)
      .slice(0, 3);
  }

  getQueryTypeDistribution(usage) {
    const typeCount = usage.reduce((count, item) => {
      count[item.query_type] = (count[item.query_type] || 0) + 1;
      return count;
    }, {});

    const total = Object.values(typeCount).reduce((sum, val) => sum + val, 0);

    return Object.entries(typeCount).map(([type, count]) => ({
      type,
      count,
      percentage: (count / total * 100).toFixed(1)
    }));
  }

  getAverageDailyUsage(usage) {
    const days = usage.reduce((dayMap, item) => {
      const day = new Date(item.timestamp).toDateString();
      if (!dayMap[day]) dayMap[day] = [];
      dayMap[day].push(item);
      return dayMap;
    }, {});

    const dailyUsage = Object.values(days).map((dayUsage: any[]) => dayUsage.length);
    const average = dailyUsage.reduce((sum, val) => sum + val, 0) / dailyUsage.length;

    return Math.round(average);
  }

  getUsageTrend(usage) {
    // Group by day and calculate trend
    const dailyUsage = usage.reduce((trend, item) => {
      const day = new Date(item.timestamp).toDateString();
      trend[day] = (trend[day] || 0) + 1;
      return trend;
    }, {});

    return Object.entries(dailyUsage)
      .sort(([a], [b]) => new Date(a).getTime() - new Date(b).getTime())
      .map(([date, count]) => ({ date, count }));
  }
}
