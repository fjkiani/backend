export const UsageTips: React.FC = () => {
  const { usage } = useUsage();

  if (!usage) return null;

  const getTips = () => {
    const tips = [];

    if (usage.tier === 'free') {
      tips.push('Consider upgrading to Pro for 50x more queries');
    }

    if (usage.usagePercentage > 70) {
      tips.push('Try batching similar queries to optimize usage');
