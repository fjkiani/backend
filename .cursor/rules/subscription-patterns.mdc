# Subscription Management Patterns

This rule covers subscription management patterns for our SaaS application, including Stripe integration and tier management.

## Stripe Integration Architecture

### 1. Subscription Service Structure
```javascript
// backend/src/services/subscription/SubscriptionService.js
export class SubscriptionService {
  constructor(stripe, supabase) {
    this.stripe = stripe;
    this.supabase = supabase;
  }

  // Tier configurations
  getTierConfig(tier) {
    const configs = {
      free: {
        priceId: null,
        queryLimit: 10,
        features: ['basic-news', 'basic-calendar']
      },
      pro: {
        priceId: process.env.STRIPE_PRO_PRICE_ID,
        queryLimit: 500,
        features: ['advanced-analytics', 'custom-dashboards', 'priority-support']
      },
      enterprise: {
        priceId: process.env.STRIPE_ENTERPRISE_PRICE_ID,
        queryLimit: -1, // Unlimited
        features: ['api-access', 'white-label', 'custom-integrations', 'dedicated-support']
      }
    };
    return configs[tier];
  }

  // Create or update customer
  async createOrUpdateCustomer(userId, email) {
    const { data: profile } = await this.supabase
      .from('user_profiles')
      .select('stripe_customer_id')
      .eq('id', userId)
      .single();

    if (profile.stripe_customer_id) {
      // Update existing customer
      return await this.stripe.customers.update(profile.stripe_customer_id, {
        email: email
      });
    } else {
      // Create new customer
      const customer = await this.stripe.customers.create({
        email: email,
        metadata: {
          userId: userId
        }
      });

      // Update profile with customer ID
      await this.supabase
        .from('user_profiles')
        .update({ stripe_customer_id: customer.id })
        .eq('id', userId);

      return customer;
    }
  }

  // Create subscription
  async createSubscription(userId, email, tier) {
    const customer = await this.createOrUpdateCustomer(userId, email);
    const tierConfig = this.getTierConfig(tier);

    const subscription = await this.stripe.subscriptions.create({
      customer: customer.id,
      items: [{
        price: tierConfig.priceId
      }],
      payment_behavior: 'default_incomplete',
      expand: ['latest_invoice.payment_intent'],
      metadata: {
        userId: userId,
        tier: tier
      }
    });

    return subscription;
  }

  // Handle subscription changes
  async updateSubscriptionStatus(userId, subscriptionId, status) {
    const updates = {
      subscription_status: status,
      updated_at: new Date().toISOString()
    };

    if (status === 'active') {
      // Get subscription details to update tier and limits
      const subscription = await this.stripe.subscriptions.retrieve(subscriptionId);
      const tier = subscription.metadata.tier;
      const tierConfig = this.getTierConfig(tier);
      
      updates.subscription_tier = tier;
      updates.query_limit = tierConfig.queryLimit;
      updates.stripe_subscription_id = subscriptionId;
    }

    await this.supabase
      .from('user_profiles')
      .update(updates)
      .eq('id', userId);
  }

  // Cancel subscription
  async cancelSubscription(userId) {
    const { data: profile } = await this.supabase
      .from('user_profiles')
      .select('stripe_subscription_id')
      .eq('id', userId)
      .single();

    if (profile.stripe_subscription_id) {
      await this.stripe.subscriptions.update(profile.stripe_subscription_id, {
        cancel_at_period_end: true
      });
    }
  }

  // Get subscription details
  async getSubscriptionDetails(userId) {
    const { data: profile } = await this.supabase
      .from('user_profiles')
      .select('*')
      .eq('id', userId)
      .single();

    if (!profile.stripe_subscription_id) {
      return null;
    }

    const subscription = await this.stripe.subscriptions.retrieve(
      profile.stripe_subscription_id
    );

    return {
      ...subscription,
      current_period_end: new Date(subscription.current_period_end * 1000),
      cancel_at_period_end: subscription.cancel_at_period_end
    };
  }
}
```

## Stripe Webhook Handling

### 1. Webhook Handler
```javascript
// backend/src/routes/webhooks/stripe.js
export const handleStripeWebhook = async (req, res) => {
  const sig = req.headers['stripe-signature'];
  let event;

  try {
    event = this.stripe.webhooks.constructEvent(
      req.body,
      sig,
      process.env.STRIPE_WEBHOOK_SECRET
    );
  } catch (err) {
    console.error('Webhook signature verification failed:', err.message);
    return res.status(400).send(`Webhook Error: ${err.message}`);
  }

  const subscriptionService = new SubscriptionService(this.stripe, req.supabase);

  try {
    switch (event.type) {
      case 'customer.subscription.created':
      case 'customer.subscription.updated':
        const subscription = event.data.object;
        const userId = subscription.metadata.userId;
        await subscriptionService.updateSubscriptionStatus(
          userId,
          subscription.id,
          subscription.status
        );
        break;

      case 'customer.subscription.deleted':
        const deletedSubscription = event.data.object;
        const deletedUserId = deletedSubscription.metadata.userId;
        await subscriptionService.updateSubscriptionStatus(
          deletedUserId,
          deletedSubscription.id,
          'cancelled'
        );
        break;

      case 'invoice.payment_succeeded':
        const invoice = event.data.object;
        if (invoice.subscription) {
          const subscription = await this.stripe.subscriptions.retrieve(
            invoice.subscription
          );
          const userId = subscription.metadata.userId;
          await subscriptionService.updateSubscriptionStatus(
            userId,
            subscription.id,
            'active'
          );
        }
        break;

      case 'invoice.payment_failed':
        const failedInvoice = event.data.object;
        if (failedInvoice.subscription) {
          const subscription = await this.stripe.subscriptions.retrieve(
            failedInvoice.subscription
          );
          const userId = subscription.metadata.userId;
          await subscriptionService.updateSubscriptionStatus(
            userId,
            subscription.id,
            'past_due'
          );
        }
        break;

      default:
        console.log(`Unhandled event type ${event.type}`);
    }

    res.json({ received: true });
  } catch (error) {
    console.error('Error handling webhook:', error);
    res.status(500).json({ error: 'Webhook handler failed' });
  }
};
```

## Frontend Subscription Management

### 1. Subscription Context and Hooks
```tsx
// src/hooks/useSubscription.ts
import { createContext, useContext, useEffect, useState } from 'react';
import { useAuth } from './useAuth';

interface SubscriptionContextType {
  subscription: any;
  tier: string;
  isLoading: boolean;
  upgradeToPro: () => Promise<void>;
  upgradeToEnterprise: () => Promise<void>;
  cancelSubscription: () => Promise<void>;
  createCheckoutSession: (tier: string) => Promise<string>;
}

const SubscriptionContext = createContext<SubscriptionContextType | undefined>(undefined);

export const SubscriptionProvider = ({ children }: { children: React.ReactNode }) => {
  const { user } = useAuth();
  const [subscription, setSubscription] = useState<any>(null);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    if (user) {
      loadSubscription();
    }
  }, [user]);

  const loadSubscription = async () => {
    try {
      const response = await apiClient.get('/api/subscription/details');
      setSubscription(response);
    } catch (error) {
      console.error('Error loading subscription:', error);
    } finally {
      setIsLoading(false);
    }
  };

  const createCheckoutSession = async (tier: string) => {
    const response = await apiClient.post('/api/subscription/create-checkout', {
      tier,
      successUrl: `${window.location.origin}/dashboard`,
      cancelUrl: `${window.location.origin}/subscription`
    });
    return response.url;
  };

  const upgradeToPro = async () => {
    const checkoutUrl = await createCheckoutSession('pro');
    window.location.href = checkoutUrl;
  };

  const upgradeToEnterprise = async () => {
    const checkoutUrl = await createCheckoutSession('enterprise');
    window.location.href = checkoutUrl;
  };

  const cancelSubscription = async () => {
    await apiClient.post('/api/subscription/cancel');
    await loadSubscription();
  };

  const value = {
    subscription,
    tier: subscription?.tier || 'free',
    isLoading,
    upgradeToPro,
    upgradeToEnterprise,
    cancelSubscription,
    createCheckoutSession
  };

  return (
    <SubscriptionContext.Provider value={value}>
      {children}
    </SubscriptionContext.Provider>
  );
};

export const useSubscription = () => {
  const context = useContext(SubscriptionContext);
  if (context === undefined) {
    throw new Error('useSubscription must be used within a SubscriptionProvider');
  }
  return context;
};
```

