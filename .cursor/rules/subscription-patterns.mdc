### 3. Usage Tracking Component
```tsx
// src/components/Subscription/UsageTracker.tsx
import { useAuth } from '../../hooks/useAuth';
import { useSubscription } from '../../hooks/useSubscription';
import { Progress } from '../ui/progress';
import { Alert } from '../ui/alert';

export const UsageTracker = () => {
  const { profile } = useAuth();
  const { tier } = useSubscription();
  
  if (!profile) return null;
  
  const { query_count, query_limit } = profile;
  const usagePercentage = (query_count / query_limit) * 100;
  const isNearLimit = usagePercentage > 80;
  const isAtLimit = query_count >= query_limit;

  return (
    <div className="bg-white p-4 rounded-lg border">
      <h3 className="font-semibold mb-2">Usage This Month</h3>
      
      <div className="flex justify-between text-sm mb-2">
        <span>Queries Used</span>
        <span>{query_count} / {query_limit === -1 ? '∞' : query_limit}</span>
      </div>
      
      {query_limit !== -1 && (
        <Progress value={usagePercentage} className="mb-2" />
      )}
      
      {isAtLimit && (
        <Alert variant="destructive">
          <p>You've reached your monthly query limit. Upgrade to continue using the service.</p>
        </Alert>
      )}
      
      {isNearLimit && !isAtLimit && (
        <Alert>
          <p>You're approaching your monthly limit. Consider upgrading for more queries.</p>
        </Alert>
      )}
      
      <div className="text-xs text-gray-500 mt-2">
        Resets on the 1st of each month
      </div>
    </div>
  );
};
```

## Subscription Management Routes

### 1. API Routes
```javascript
// backend/src/routes/subscription.js
import { Router } from 'express';
import { SubscriptionService } from '../services/subscription/SubscriptionService.js';
import { authenticateUser } from '../middleware/auth.js';

const router = Router();

// Get subscription details
router.get('/details', authenticateUser, async (req, res) => {
  try {
    const subscriptionService = new SubscriptionService(req.stripe, req.supabase);
    const details = await subscriptionService.getSubscriptionDetails(req.user.id);
    res.json(details);
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// Create checkout session
router.post('/create-checkout', authenticateUser, async (req, res) => {
  try {
    const { tier, successUrl, cancelUrl } = req.body;
    const subscriptionService = new SubscriptionService(req.stripe, req.supabase);
    
    const { data: profile } = await req.supabase
      .from('user_profiles')
      .select('email')
      .eq('id', req.user.id)
      .single();
    
    const session = await subscriptionService.createCheckoutSession(
      req.user.id,
      profile.email,
      tier,
      successUrl,
      cancelUrl
    );
    
    res.json({ url: session.url });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// Cancel subscription
router.post('/cancel', authenticateUser, async (req, res) => {
  try {
    const subscriptionService = new SubscriptionService(req.stripe, req.supabase);
    await subscriptionService.cancelSubscription(req.user.id);
    res.json({ success: true });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// Update subscription
router.post('/update', authenticateUser, async (req, res) => {
  try {
    const { newTier } = req.body;
    const subscriptionService = new SubscriptionService(req.stripe, req.supabase);
    
    const { data: profile } = await req.supabase
      .from('user_profiles')
      .select('email')
      .eq('id', req.user.id)
      .single();
    
    const session = await subscriptionService.updateSubscription(
      req.user.id,
      profile.email,
      newTier
    );
    
    res.json({ url: session.url });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

export default router;
```

## Billing and Invoicing

### 1. Invoice Management
```javascript
// backend/src/services/billing/InvoiceService.js
export class InvoiceService {
  constructor(stripe, supabase) {
    this.stripe = stripe;
    this.supabase = supabase;
  }

  async getUserInvoices(userId) {
    const { data: profile } = await this.supabase
      .from('user_profiles')
      .select('stripe_customer_id')
      .eq('id', userId)
      .single();
    
    if (!profile.stripe_customer_id) {
      return [];
    }
    
    const invoices = await this.stripe.invoices.list({
      customer: profile.stripe_customer_id,
      limit: 20
    });
    
    return invoices.data;
  }

  async downloadInvoice(invoiceId) {
    const invoice = await this.stripe.invoices.retrieve(invoiceId);
    return invoice.invoice_pdf;
  }

  async getUpcomingInvoice(userId) {
    const { data: profile } = await this.supabase
      .from('user_profiles')
      .select('stripe_customer_id')
      .eq('id', userId)
      .single();
    
    if (!profile.stripe_customer_id) {
      return null;
    }
    
    const invoice = await this.stripe.invoices.retrieveUpcoming({
      customer: profile.stripe_customer_id
    });
    
    return invoice;
  }
}
```

## Tier-Based Feature Access

### 1. Feature Gates
```javascript
// backend/src/middleware/featureGates.js
export const requireTier = (requiredTier) => {
  return (req, res, next) => {
    const userTier = req.subscription?.tier || 'free';
    const tierHierarchy = { free: 0, pro: 1, enterprise: 2 };
    
    if (tierHierarchy[userTier] < tierHierarchy[requiredTier]) {
      return res.status(402).json({
        error: 'Insufficient subscription tier',
        required: requiredTier,
        current: userTier,
        message: `This feature requires ${requiredTier} subscription.`
      });
    }
    
    next();
  };
};

// Usage in routes
router.post('/advanced-analysis', 
  authenticateUser, 
  requireTier('pro'), 
  async (req, res) => {
    // Only Pro and Enterprise users can access this
  }
);
```

### 2. Frontend Feature Gates
```tsx
// src/components/FeatureGate.tsx
import { useSubscription } from '../hooks/useSubscription';
import { UpgradeModal } from './Subscription/UpgradeModal';

interface FeatureGateProps {
  requiredTier: 'pro' | 'enterprise';
  children: React.ReactNode;
  fallback?: React.ReactNode;
  showUpgrade?: boolean;
}

export const FeatureGate = ({ 
  requiredTier, 
  children, 
  fallback,
  showUpgrade = true 
}: FeatureGateProps) => {
  const { tier } = useSubscription();
  const [showUpgradeModal, setShowUpgradeModal] = useState(false);
  
  const tierHierarchy = { free: 0, pro: 1, enterprise: 2 };
  const hasAccess = tierHierarchy[tier] >= tierHierarchy[requiredTier];
  
  if (hasAccess) {
    return <>{children}</>;
  }
  
  if (fallback) {
    return <>{fallback}</>;
  }
  
  if (showUpgrade) {
    return (
      <>
        <button
          onClick={() => setShowUpgradeModal(true)}
          className="text-blue-600 underline"
        >
          Upgrade to access this feature
        </button>
        <UpgradeModal 
          isOpen={showUpgradeModal}
          onClose={() => setShowUpgradeModal(false)}
          requiredTier={requiredTier}
        />
      </>
    );
  }
  
  return null;
};
```

## Analytics and Reporting

### 1. Subscription Analytics
```javascript
// backend/src/services/analytics/SubscriptionAnalytics.js
export class SubscriptionAnalytics {
  constructor(supabase) {
    this.supabase = supabase;
  }

  async getSubscriptionMetrics() {
    const { data } = await this.supabase
      .from('user_profiles')
      .select('subscription_tier, created_at, query_count');
    
    const metrics = {
      totalUsers: data.length,
      tierBreakdown: {},
      averageUsage: {},
      churnRate: 0
    };
    
    // Calculate metrics
    data.forEach(user => {
      metrics.tierBreakdown[user.subscription_tier] = 
        (metrics.tierBreakdown[user.subscription_tier] || 0) + 1;
    });
    
    return metrics;
  }

  async getRevenueMetrics() {
    // This would integrate with Stripe reporting or our own revenue tracking
    const { data } = await this.supabase
      .from('subscription_events')
      .select('amount, currency, created_at')
      .eq('event_type', 'payment_succeeded');
    
    return data.reduce((acc, payment) => ({
      totalRevenue: acc.totalRevenue + payment.amount,
      paymentsCount: acc.paymentsCount + 1
    }), { totalRevenue: 0, paymentsCount: 0 });
  }
}
```

